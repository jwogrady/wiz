# --- GitHub and Git Configuration ---

# Your GitHub username (required)
GITHUB_USERNAME=exampleuser

# Name of your dotfiles repository (required)
GITHUB_DOTFILES_REPO_NAME=dotfiles

# Full URL to your dotfiles repository (auto-generated if using above variables)
# If you set this, it will override the auto-generated URL
GITHUB_DOTFILES_REPO_URL=https://github.com/${GITHUB_USERNAME}/${GITHUB_DOTFILES_REPO_NAME}.git

# Git user email (required for git config)
GIT_EMAIL=example@email.com

# Git user name (required for git config)
GIT_USER=Example Name

# --- SSH Key Extraction ---
# Path to your SSH keys archive (tar.gz, zip, etc.)
KEYS_SRC=/mnt/c/Users/example/keys.tar.gz
# Destination directory for extracted keys (usually $HOME or $HOME/.ssh)
KEYS_DEST=$HOME

# --- Optional: Shell and Environment ---
# Set your preferred shell (e.g., /bin/bash, /bin/zsh)
# SHELL_PATH=/bin/bash

# --- Optional: Additional Environment Variables ---
# Add any other environment variables you want available to the bootstrap scripts below
# EXAMPLE_VAR=value
