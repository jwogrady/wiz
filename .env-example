# --- GitHub and Git Configuration ---

# Your GitHub username
GITHUB_USERNAME=exampleuser

# Name of your dotfiles repository
GITHUB_DOTFILES_REPO_NAME=dotfiles

# Full URL to your dotfiles repository (auto-generated if using above variables)
GITHUB_DOTFILES_REPO_URL=https://github.com/${GITHUB_USERNAME}/${GITHUB_DOTFILES_REPO_NAME}.git

# Git user email
GIT_EMAIL=example@email.com

# Git user name
GIT_USER=Example Name

KEYS_SRC=/mnt/c/Users/example/keys.tar.gz
KEYS_DEST=$HOME
