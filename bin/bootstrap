#!/usr/bin/env bash
# ==============================================================================
# Wiz - Terminal Magic: Bootstrap Script
# ==============================================================================
# This script is designed to be curl-piped from GitHub for initial setup.
# It clones the repo and runs the installer.
#
# Usage:
#   curl -fsSL https://raw.githubusercontent.com/jwogrady/wiz/master/bin/bootstrap | bash
#
#   # Install from a specific branch:
#   curl -fsSL https://raw.githubusercontent.com/jwogrady/wiz/<branch>/bin/bootstrap | WIZ_BRANCH=<branch> bash
#
#   # Pass options to the installer:
#   curl -fsSL .../bin/bootstrap | WIZ_ARGS="--keys-path=/mnt/d/OneDrive/keys.tar.gz" bash
#
# ==============================================================================

set -euo pipefail

# --- Self-contained logging (cannot source lib/common.sh before clone) ---
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly NC='\033[0m'

log()     { echo -e "${BLUE}[INFO]${NC} $*"; }
success() { echo -e "${GREEN}[OK]${NC} $*"; }
warn()    { echo -e "${YELLOW}[WARN]${NC} $*"; }
error()   { echo -e "${RED}[ERROR]${NC} $*" >&2; exit 1; }

# --- Banner ---
show_banner() {
    cat << 'EOF'

╔════════════════════════════════════════════════════════════╗
║                                                            ║
║   🌌  WIZ - TERMINAL MAGIC  ✨                            ║
║                                                            ║
║   Bootstrap Installer                                      ║
║   https://github.com/jwogrady/wiz                          ║
║                                                            ║
╚════════════════════════════════════════════════════════════╝

EOF
}

# --- Check Requirements ---
check_requirements() {
    local missing=()

    for cmd in git curl; do
        if ! command -v "$cmd" >/dev/null 2>&1; then
            missing+=("$cmd")
        fi
    done

    if [[ ${#missing[@]} -gt 0 ]]; then
        error "Missing required commands: ${missing[*]}"
    fi
}

# --- Main ---
main() {
    show_banner

    log "Starting Wiz bootstrap..."
    echo ""

    # Check requirements
    check_requirements

    # Define installation directory
    local WIZ_DIR="${HOME}/wiz"
    local branch="${WIZ_BRANCH:-master}"

    # Clone or update repository
    if [[ -d "$WIZ_DIR" ]]; then
        log "Wiz directory already exists at ${WIZ_DIR}"
        log "Updating existing repository..."
        cd "$WIZ_DIR"
        git fetch origin "$branch" 2>/dev/null || true
        git checkout "$branch" 2>/dev/null || {
            warn "Could not checkout branch ${branch}, using current"
        }
        git pull origin "$branch" 2>/dev/null || {
            warn "Could not update repository, using existing version"
        }
    else
        log "Cloning Wiz repository..."
        git clone -b "$branch" https://github.com/jwogrady/wiz.git "$WIZ_DIR" || error "Failed to clone repository"
        success "Repository cloned to ${WIZ_DIR} (branch: ${branch})"
    fi

    echo ""
    log "Switching to ${WIZ_DIR}..."
    cd "$WIZ_DIR"

    # Make install script executable
    chmod +x bin/install

    # Run installer
    echo ""
    log "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    log "Starting Wiz installer..."
    log "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    # When piped via curl, $@ is empty. WIZ_ARGS lets users pass installer
    # options through the pipe: curl ... | WIZ_ARGS="--flag" bash
    local -a install_args=("$@")
    if [[ ${#install_args[@]} -eq 0 && -n "${WIZ_ARGS:-}" ]]; then
        IFS=' ' read -ra install_args <<< "$WIZ_ARGS"
    fi

    exec ./bin/install "${install_args[@]}"
}

main "$@"
